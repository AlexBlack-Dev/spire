{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SPIRE",
  "version": "1.0.0",
  "identifier": "com.spire.notes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SPIRE",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 680,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "icons/spire-file.ico"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      { "ext": ["txt", "md", "html", "json", "xml", "yaml", "yml", "csv", "css", "js", "ts", "py", "rs", "java", "c", "cpp", "h", "hpp", "ini", "cfg", "conf", "log", "sql", "svg", "toml"], "name": "Text Files" },
      { "ext": ["xlsx", "xls", "ods"], "name": "Spreadsheet Files" }
    ]
  }
}
